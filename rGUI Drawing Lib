                end
            end,
        },
        Outline = {
            type = 'boolean',
            func = function(boolean)
                if (boolean) then
                    GUI.text.TextStrokeTransparency = 0;
                else
                    GUI.text.TextStrokeTransparency = 1;
                end
            end,
        },
        OutlineColor = {
            type = 'Color3',
